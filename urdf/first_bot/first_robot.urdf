<?xml version="1.0"?>
<robot name="first_robot">
    <!-- Ctrl+/ 添加注释，下面添加机器人身体部分 -->
     <link name="base_link">
        <!-- 部件的外观描述 -->
         <visual>
            <!-- 下面是相对自己几何中心的偏移和旋转 -->
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <!-- 几何形状 -->
             <geometry>
                <!-- 圆柱体 -->
                <cylinder radius="0.10" length="0.12"/>
             </geometry>
             <!-- 材质和颜色 -->
              <material name="white">
                <color rgba="1.0 1.0 1.0 0.5"/>
              </material>
         </visual>
     </link>

     <!-- 机器人的IMU部件，惯性测量传感器 -->
    <link name="imu_link">
        <!-- 部件的外观描述 -->
         <visual>
            <!-- 下面是相对自己几何中心的偏移和旋转 -->
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <!-- 几何形状 -->
             <geometry>
                <box size="0.02 0.02 0.02"/>
             </geometry>
             <!-- 材质和颜色 -->
              <material name="black">
                <color rgba="0.0 0.0 0.0 0.5"/>
              </material>
         </visual>
     </link>

     <!-- 机器人的关节，主要用来组合机器人的部件 -->
      <joint name="imu_name" type="fixed">
        <origin xyz="0.0 0.0 0.03" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="imu_link"/>
      </joint>
    
</robot>
